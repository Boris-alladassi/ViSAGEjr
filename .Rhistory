founderPop = quickHaplo(nInd=110, nChr=1, segSites=100)
SP <- SimParam$new(founderPop)
SP <- SimParam$new(founderPop)
SP$resetPed()
SP$addTraitAE(nQtlPerChr = 50, mean=150, var=80, relAA = 0.3)
pop <-  newPop(founderPop, simParam=SP)
pop <- setPheno(pop, H2=0.8, simParam=SP)
get.me.my.SNPs.in.hapmap.format <- function(these.SNPs = NA,
this.physical.map = NA){
# Subtract the numeric genotypes so that they range from -1,0,1
these.SNPs.minus.one <- these.SNPs-1
#Arrange the SNPs and genetic map  so that they are in a HapMap-like format
# for simplePHENOTYPES
hapmap.file.of.these.SNPs <- data.frame(
snp = colnames(these.SNPs.minus.one),
allele = rep("A/G", ncol(these.SNPs.minus.one)),
chr = this.physical.map$chr,
pos = this.physical.map$pos,
cm = rep(NA, ncol(these.SNPs.minus.one)),
t(these.SNPs.minus.one)
)
return(hapmap.file.of.these.SNPs)
}
bp_qtl_map <- AlphaSimR::getQtlMap(trait = 1, simParam = SP)
bp_qtl_geno <- AlphaSimR::pullQtlGeno(pop, trait = 1, simParam = SP)
bp_qtls_hapmap <- get.me.my.SNPs.in.hapmap.format(these.SNPs = bp_qtl_geno, this.physical.map = bp_qtl_map)
geno_dt <- bp_qtl_geno
pheno_dt <- as.data.frame(gv(pop))
trait = "Trait1"
geno_df <- data.frame(ID = paste0("id",1:nrow(geno_dt)), geno_dt)
pheno_df <- data.frame(ID = paste0("id",1:nrow(geno_dt)), pheno_dt)
# -------------------------
# Merge data
# -------------------------
merged_df <- dplyr::inner_join(geno_df, pheno_df, by = "ID")
trait_name <- colnames(pheno_df)[2]
markers <- colnames(geno_df)[-1]
nloci = ncol(geno_df)-1
nindiv = nrow(geno_df)
# -------------------------
# Convert to long format
# -------------------------
long_df <- tidyr::pivot_longer(
data = merged_df,
cols = dplyr::all_of(markers),
names_to = "SNP",
values_to = "Dosage"
)
View(long_df)
# -------------------------
# Genotype means and counts
# -------------------------
genotype_stats <- dplyr::group_by(long_df, SNP, Dosage) |>
dplyr::summarise(
mean_trait = mean(.data[[trait_name]], na.rm = TRUE),
n = dplyr::n(),
.groups = "drop"
)
# -------------------------
# Allele frequency
# -------------------------
allele_freq <- tidyr::pivot_wider(
dplyr::select(genotype_stats, -mean_trait),
names_from = Dosage,
values_from = n, names_prefix = "freq_") |>
dplyr::mutate(p = (2*freq_0 + freq_1)/(2*nindiv),
q = 1-p)
# -------------------------
# Gene action effect: a & d
# -------------------------
a_d_effect <- tidyr::pivot_wider(
dplyr::select(genotype_stats, -n),
names_from = Dosage,
values_from = mean_trait,
names_prefix = "mu_") |>
dplyr::mutate(a = (mu_0 - mu_2)/2,
d = mu_1 - (mu_0 + mu_2)/2)
View(a_d_effect)
View(allele_freq)
View(genotype_stats)
#'
#' @return A data.frame with SNP effects and variance components.
#'
#' @details
#' Assumes:
#' - Both data frames contain a column named "ID"
#' - SNP genotypes are coded 0, 1, 2
#' - The first phenotype column (after ID) is used
#'
#' @export
compute_variances <- function(pop, sp_object) {
qtl_geno <- AlphaSimR::pullQtlGeno(pop, trait = 1, simParam = SP_object)
pheno_dt <- as.data.frame(AlphaSimR::gv(pop))
geno_df <- data.frame(ID = paste0("id",1:nrow(geno_dt)), geno_dt)
pheno_df <- data.frame(ID = paste0("id",1:nrow(geno_dt)), pheno_dt)
# -------------------------
# Input validation
# -------------------------
if (!"ID" %in% colnames(geno_df)) {
stop("geno_df must contain an 'ID' column.")
}
if (!"ID" %in% colnames(pheno_df)) {
stop("pheno_df must contain an 'ID' column.")
}
if (ncol(pheno_df) < 2) {
stop("pheno_df must contain at least one trait column.")
}
# -------------------------
# Merge data
# -------------------------
merged_df <- dplyr::inner_join(geno_df, pheno_df, by = "ID")
trait_name <- colnames(pheno_df)[2]
markers <- colnames(geno_df)[-1]
nloci = ncol(geno_df)-1
nindiv = nrow(geno_df)
# -------------------------
# Convert to long format
# -------------------------
long_df <- tidyr::pivot_longer(
data = merged_df,
cols = dplyr::all_of(markers),
names_to = "SNP",
values_to = "Dosage"
)
# -------------------------
# Genotype means and counts
# -------------------------
genotype_stats <- dplyr::group_by(long_df, SNP, Dosage) |>
dplyr::summarise(
mean_trait = mean(.data[[trait_name]], na.rm = TRUE),
n = dplyr::n(),
.groups = "drop"
)
# -------------------------
# Allele frequency
# -------------------------
allele_freq <- tidyr::pivot_wider(
dplyr::select(genotype_stats, -mean_trait),
names_from = Dosage,
values_from = n, names_prefix = "freq_") |>
dplyr::mutate(p = (2*freq_0 + freq_1)/(2*nindiv),
q = 1-p)
# -------------------------
# Gene action effect: a & d
# -------------------------
a_d_effect <- tidyr::pivot_wider(
dplyr::select(genotype_stats, -n),
names_from = Dosage,
values_from = mean_trait,
names_prefix = "mu_") |>
dplyr::mutate(a = (mu_0 - mu_2)/2,
d = mu_1 - (mu_0 + mu_2)/2)
# -------------------------
# Compute genetic effects
# -------------------------
eff_and_var <- dplyr::full_join(a_d_effect, allele_freq) |>
dplyr::mutate(
# Average effect of allele substitution
alpha = a + d * (q - p),
# Variance components
additive_variance = 2 * p * q * (alpha^2),
dominance_variance = (2 * p * q * d)^2)
varAdd <- sum(eff_and_var$additive_variance)
vardom <- sum(eff_and_var$dominance_variance)
vargen <- var(pheno_df[[trait]])
varepi <- vargen - (varAdd + vardom)
return(list(eff_and_var = eff_and_var, vargen = vargen,
varAdd = varAdd, vardom = vardom, varepi = varepi))
}
res <- compute_variances(pop = pop, sp_object = SP)
#'
#' @return A data.frame with SNP effects and variance components.
#'
#' @details
#' Assumes:
#' - Both data frames contain a column named "ID"
#' - SNP genotypes are coded 0, 1, 2
#' - The first phenotype column (after ID) is used
#'
#' @export
compute_variances <- function(pop, SP_object) {
qtl_geno <- AlphaSimR::pullQtlGeno(pop, trait = 1, simParam = SP_object)
pheno_dt <- as.data.frame(AlphaSimR::gv(pop))
geno_df <- data.frame(ID = paste0("id",1:nrow(geno_dt)), geno_dt)
pheno_df <- data.frame(ID = paste0("id",1:nrow(geno_dt)), pheno_dt)
# -------------------------
# Input validation
# -------------------------
if (!"ID" %in% colnames(geno_df)) {
stop("geno_df must contain an 'ID' column.")
}
if (!"ID" %in% colnames(pheno_df)) {
stop("pheno_df must contain an 'ID' column.")
}
if (ncol(pheno_df) < 2) {
stop("pheno_df must contain at least one trait column.")
}
# -------------------------
# Merge data
# -------------------------
merged_df <- dplyr::inner_join(geno_df, pheno_df, by = "ID")
trait_name <- colnames(pheno_df)[2]
markers <- colnames(geno_df)[-1]
nloci = ncol(geno_df)-1
nindiv = nrow(geno_df)
# -------------------------
# Convert to long format
# -------------------------
long_df <- tidyr::pivot_longer(
data = merged_df,
cols = dplyr::all_of(markers),
names_to = "SNP",
values_to = "Dosage"
)
# -------------------------
# Genotype means and counts
# -------------------------
genotype_stats <- dplyr::group_by(long_df, SNP, Dosage) |>
dplyr::summarise(
mean_trait = mean(.data[[trait_name]], na.rm = TRUE),
n = dplyr::n(),
.groups = "drop"
)
# -------------------------
# Allele frequency
# -------------------------
allele_freq <- tidyr::pivot_wider(
dplyr::select(genotype_stats, -mean_trait),
names_from = Dosage,
values_from = n, names_prefix = "freq_") |>
dplyr::mutate(p = (2*freq_0 + freq_1)/(2*nindiv),
q = 1-p)
# -------------------------
# Gene action effect: a & d
# -------------------------
a_d_effect <- tidyr::pivot_wider(
dplyr::select(genotype_stats, -n),
names_from = Dosage,
values_from = mean_trait,
names_prefix = "mu_") |>
dplyr::mutate(a = (mu_0 - mu_2)/2,
d = mu_1 - (mu_0 + mu_2)/2)
# -------------------------
# Compute genetic effects
# -------------------------
eff_and_var <- dplyr::full_join(a_d_effect, allele_freq) |>
dplyr::mutate(
# Average effect of allele substitution
alpha = a + d * (q - p),
# Variance components
additive_variance = 2 * p * q * (alpha^2),
dominance_variance = (2 * p * q * d)^2)
varAdd <- sum(eff_and_var$additive_variance)
vardom <- sum(eff_and_var$dominance_variance)
vargen <- var(pheno_df[[trait]])
varepi <- vargen - (varAdd + vardom)
return(list(eff_and_var = eff_and_var, vargen = vargen,
varAdd = varAdd, vardom = vardom, varepi = varepi))
}
res <- compute_variances(pop = pop, SP_object = SP)
View(res)
